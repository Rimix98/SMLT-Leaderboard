# SMLT Demonlist — Environment Variables
# Copy this file, rename to .env.local, and fill in your values.
# NEVER commit .env.local or serviceAccountKey.json to git.

# === REQUIRED ===

# Bcrypt hash of the admin (host) password.
# Generate with: go run tools/hash.go "your-password"
ADMIN_HASH="$2a$10$..."

# JWT signing secret — minimum 32 characters, use a cryptographically random string.
# Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-random-string-at-least-32-chars"

# Firebase service account JSON — the entire JSON object as a single line.
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate key
FIREBASE_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"...",...}'

# === RECOMMENDED (for distributed rate limiting on Vercel) ===

# Upstash Redis REST URL.
# Get from: Upstash Console → Database → REST API → UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_URL="https://<id>.upstash.io"

# Upstash Redis REST token.
# Get from: Upstash Console → Database → REST API → UPSTASH_REDIS_REST_TOKEN
UPSTASH_REDIS_REST_TOKEN="<token>"

# === OPTIONAL ===

# Set to "true" to trust X-Forwarded-For / X-Vercel-Forwarded-For headers.
# Automatic on Vercel (when VERCEL=1). Set manually for other proxies.
TRUST_PROXY="false"
